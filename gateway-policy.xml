<policies>
    <inbound>
        <base />
        <set-backend-service backend-id="openai-backend" />
        <authentication-managed-identity resource="https://cognitiveservices.azure.com" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
        <!-- Inject tracking and metadata headers into client response -->
        <set-header name="x-apim-request-id" exists-action="override">
            <value>@(context.RequestId.ToString())</value>
        </set-header>
        <set-header name="x-apim-model" exists-action="override">
            <value>@(context.Response.Headers.GetValueOrDefault("x-ms-deployment-name","unknown"))</value>
        </set-header>
        <set-header name="x-apim-region" exists-action="override">
            <value>@(context.Response.Headers.GetValueOrDefault("x-ms-region","unknown"))</value>
        </set-header>
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
